#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

print_help() {
    cat <<EOF
opencode-environment local CLI

Usage:
  ./bin/oe <command>

Commands:
  setup     Initialize local environment configuration
  doctor    Validate local machine and environment readiness
  cleanup   Remove bootstrap artifacts from the workbench
  start     Start the Docker Compose workbench
  enter     Enter the running opencode runtime
  help      Show this help message
  speckit:visual <project-slug> <discover|capture|all> [extra-args]
            Discover prototype screens and capture visual artifacts
  speckit:frontend-stage <project-slug> <create|install|start|build|test|copy-to|clean> [args]
            Create and operate a temporary frontend staging app from design-context artifacts

Examples:
  ./bin/oe setup
  ./bin/oe doctor
  ./bin/oe start
  ./bin/oe enter
  ./bin/oe cleanup
EOF
}

fail() {
    printf '\033[0;31m  ✗ %s\033[0m\n' "$*" >&2
    echo
    print_help
    exit 1
}

main() {
    local cmd="${1:-help}"

    case "$cmd" in
        setup)
            shift; exec "$REPO_ROOT/dev/scripts/setup.sh" "$@"
            ;;
        doctor)
            shift; exec "$REPO_ROOT/dev/scripts/doctor.sh" "$@"
            ;;
        cleanup)
            shift; exec "$REPO_ROOT/dev/scripts/cleanup.sh" "$@"
            ;;
        start)
            shift; exec "$REPO_ROOT/dev/scripts/start.sh" "$@"
            ;;
        enter)
            shift; exec "$REPO_ROOT/dev/scripts/enter.sh" "$@"
            ;;
        speckit:visual)
            shift; exec "$REPO_ROOT/dev/scripts/wrapper.sh" speckit:visual "$@"
            ;;
        speckit:frontend-stage)
            shift; exec "$REPO_ROOT/dev/scripts/wrapper.sh" speckit:frontend-stage "$@"
            ;;
        help|--help|-h)
            print_help
            ;;
        *)
            printf '\033[0;31m  ✗ Unknown command: %s\033[0m\n' "$cmd" >&2
            echo
            print_help
            exit 1
            ;;
    esac
}

main "$@"
